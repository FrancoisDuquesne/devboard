# REQUIRED: GitLab instance hostname (no protocol, no trailing slash)
GITLAB_HOST=gitlab.example.com

# GitLab personal access token (api scope required)
# Falls back to glab CLI config if not set
# GITLAB_PRIVATE_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Worktree tracking (enable via settings toggle in the UI)
# Comma-separated parent directories to scan for git worktrees
# WORKTREE_SCAN_DIRS=/home/user/repos,/home/user/projects
